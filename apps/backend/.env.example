NODE_ENV=development
PORT=8000
LOG_LEVEL=debug

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=serviequipos
DB_SCHEMA=public

# ----- Base de datos para pruebas (integración + e2e) -----
# Apunta SIEMPRE a una base DESECHABLE: las suites la limpian en cada corrida.
# Para correr los tests localmente, copia estos valores a `.env.test.local`
# (gitignoreado) con tus credenciales reales. Ver `test/README.md`.
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USERNAME=postgres
TEST_DB_PASSWORD=postgres
TEST_DB_NAME=serviequipos_test
TEST_DB_SCHEMA=public

# JWT
JWT_SECRET=change-me-with-openssl-rand-base64-32
JWT_EXPIRES_IN=7d

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/iam/auth/google/callback

# Microsoft OAuth (Azure Portal > Microsoft Entra ID > App registrations)
# - MICROSOFT_CLIENT_ID: "Application (client) ID" de la app registrada.
# - MICROSOFT_CLIENT_SECRET: el "Value" del secret (NO el "Secret ID").
#   Solo se muestra una vez al crearlo en Certificates & secrets.
# - MICROSOFT_TENANT: 'common' acepta cuentas de organización y personales
#   (@outlook/@hotmail). Pon tu Tenant ID solo para restringir a tu org.
# - Las Redirect URIs deben registrarse en Authentication (usar HTTPS en prod).
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT=common
MICROSOFT_CALLBACK_URL=http://localhost:8000/api/v1/iam/auth/microsoft/callback

# SendGrid (for OTP emails)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=no-reply@serviequipos.com
SENDGRID_FROM_NAME=serviequipos

# Email Firewall
# - EMAIL_FIREWALL_ENABLED: "true" para activar el firewall
# - EMAIL_FIREWALL_DEV_EMAIL: en NODE_ENV=development, redirige todos los emails aquí
# - EMAIL_FIREWALL_ALLOWED_EMAILS: lista separada por comas. Soporta wildcards de dominio: *@dominio.com
EMAIL_FIREWALL_ENABLED=false
EMAIL_FIREWALL_DEV_EMAIL=
EMAIL_FIREWALL_ALLOWED_EMAILS=

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# ====================================================================
# Storage / Digital Ocean Spaces (S3-compatible)
# ====================================================================

# Endpoint regional del Space. Formato:
#   https://<region>.digitaloceanspaces.com
# La región va en el subdominio (nyc3, sfo3, ams3, sgp1, fra1, etc.).
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# Región del Space — debe coincidir con la del endpoint. AWS SDK la
# exige para firmar requests.
DO_SPACES_REGION=nyc3

# Nombre del Space (bucket). Debe existir previamente en el panel de DO.
DO_SPACES_BUCKET=serviequipos-files

# Access Key y Secret generadas en DO panel > API > Spaces Keys. Tienen
# alcance a TODOS los Spaces de la cuenta (no hay scoping por bucket).
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=

# Base URL pública para archivos `public-read`. Si tienes un CDN de
# Spaces configurado, va aquí (ej. https://cdn.serviequipos.com). Si se
# omite, se construye como https://<bucket>.<endpoint-host>.
DO_SPACES_PUBLIC_URL=
