    "test:integration": "jest --config ./test/jest-integration.js --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.js --runInBand",
    "test:all": "jest && jest --config ./test/jest-integration.js --runInBand && jest --config ./test/jest-e2e.js --runInBand"
